@implements IDisposable
@inject IJSRuntime JS

<NavigationLock OnBeforeInternalNavigation="OnBeforeInternalNavigation"></NavigationLock>

<EditForm EditContext="editContext" OnValidSubmit="OnValidSubmit">
    <DataAnnotationsValidator />
    <BPInputText Label="Nombre"@bind-Value="@Actor.Nombre" />
    <BPInputDate Label="Fecha de nacimiento" @bind-Value="@Actor.FechaNacimiento" />
    <InputImg Label="Foto del actor" ImagenSeleccionada="archivo => Actor.FotoArchivo = archivo"
         ImageUrl="@Actor.FotoUrl"/>
    <BPBoton Tipo="BotonTipo.Submit" Disabled="FormularioInvalido || EnvioEnCurso" >
        @(EnvioEnCurso ?@<text>Enviando...</text> : @<text>Enviar</text>)
    </BPBoton>
</EditForm>

@code {
    private EditContext? editContext;
    private bool formularioInvalido = true;
    [Parameter, EditorRequired] public Actor Actor { get; set; } = null!;
    [Parameter, EditorRequired] public bool FormularioEnviadoConExito { get; set; } = false;
    [Parameter, EditorRequired] public bool EnvioEnCurso { get; set; } = false;
    [Parameter, EditorRequired] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public bool FormularioInvalido { get; set; } = true;

    protected override void OnInitialized()
    {
        editContext = new EditContext(Actor);
        editContext.OnFieldChanged += HandleFieldChange;
        formularioInvalido = FormularioInvalido;
    }

    private void HandleFieldChange(object? sender, FieldChangedEventArgs e)
    {
        if (editContext is not null)
        {
            formularioInvalido = !editContext.Validate();
            StateHasChanged();
        }
    }

    private async Task OnBeforeInternalNavigation(LocationChangingContext context)
    {
        var formularioFueEditado = editContext!.IsModified();

        if (!formularioFueEditado)
        {
            return;
        }

        if (FormularioEnviadoConExito)
        {
            return;
        }

        var confirmado = await JS.InvokeAsync<bool>("confirm", "¿Deseas salir y perder los cambios?");

        if (confirmado)
        {
            return;
        }

        context.PreventNavigation();
    }

    public void Dispose()
    {
        if (editContext is not null)
        {
            editContext.OnFieldChanged -= HandleFieldChange;
        }
    }
}
